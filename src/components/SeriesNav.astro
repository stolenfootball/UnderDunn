---
interface Props {
  seriesName: string;
  current: number;
  total: number;
  prev?: { title: string; slug: string };
  next?: { title: string; slug: string };
  section: string;
}

const { seriesName, current, total, prev, next, section } = Astro.props;
const displayName = seriesName.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
---
<nav class="bg-accent-hover text-white rounded-lg px-4 py-3 mb-8" aria-label="Series navigation">
  <div class="flex items-center justify-between flex-wrap gap-2">
    <div class="flex items-center gap-3">
      {prev ? (
        <a href={`/${section}/${prev.slug}`} class="text-sm text-white hover:underline" title={prev.title}>
          &larr; Prev
        </a>
      ) : (
        <span class="text-sm text-white/50">&larr; Prev</span>
      )}
    </div>

    <div class="text-center">
      <span class="font-serif font-semibold">{displayName}</span>
      <span class="text-sm text-white/70 ml-2">Part {current} of {total}</span>
    </div>

    <div class="flex items-center gap-3">
      {next ? (
        <a href={`/${section}/${next.slug}`} class="text-sm text-white hover:underline" title={next.title}>
          Next &rarr;
        </a>
      ) : (
        <span class="text-sm text-white/50">Next &rarr;</span>
      )}
    </div>
  </div>
</nav>
