---
const currentPath = Astro.url.pathname;
const links = [
  { label: 'All Posts', path: '/posts' },
  { label: 'Writeups', path: '/writeups' },
  { label: 'Research', path: '/research' },
  { label: 'Series', path: '/series' },
  { label: 'Personal', path: '/personal' },
  { label: 'About', path: '/about' },
];
---
<aside class="lg:w-80 shrink-0 bg-accent-hover border-b lg:border-b-0 lg:border-r border-accent-hover lg:self-stretch">
  <div class="lg:sticky lg:top-0 px-10 pt-24 pb-14 text-center">
    <img
      src="/images/avatar.png"
      alt="Jeremy Dunn"
      class="w-56 h-56 rounded-full mx-auto border-4 border-white/30"
    />
    <h2 class="font-serif text-4xl font-bold text-white mt-6">Jeremy Dunn</h2>
    <p class="text-xl text-white/80 mt-3">By the way - is there anyone on board who knows how to fly a plane?</p>

    <div class="mt-12 flex flex-col gap-3">
      {links.map(({ label, path }) => (
        <a
          href={path}
          class:list={[
            'text-lg font-serif font-semibold transition-colors',
            currentPath === path || (path !== '/' && currentPath.startsWith(path))
              ? 'text-white'
              : 'text-white/90 hover:text-white',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <nav class="mt-12 flex flex-wrap justify-center gap-5">
