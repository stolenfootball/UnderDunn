---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---
{filtered.length > 0 && (
  <nav aria-label="Table of contents">
    <p class="text-xs font-medium uppercase tracking-wider text-muted dark:text-muted-dark mb-3">On this page</p>
    <ul class="space-y-1.5 text-sm">
      {filtered.map(heading => (
        <li>
          <a href={`#${heading.slug}`} class:list={['block text-muted dark:text-muted-dark hover:text-accent transition-colors', heading.depth === 3 ? 'pl-4' : '']}>
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
